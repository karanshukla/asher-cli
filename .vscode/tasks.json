{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Asher",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m asher",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
